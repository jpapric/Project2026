<UserControl x:Class="Client.Views.EAFView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#0F0F0F"
             xmlns:viewModels="clr-namespace:Client.ViewModel"
             d:DataContext="{d:DesignInstance viewModels:EAFViewModel}">
    


    <UserControl.Resources>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#00BFFF"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="42" Height="42" Margin="0,0,10,0"
                           Source="C:\Users\Acer\Desktop\Praksa2026\Project\Client\images\danieliLogo.jpg"/>
                    <Image Width="42" Height="42" Margin="0,0,15,0"
                           Source="C:\Users\Acer\Desktop\Praksa2026\Project\Client\images\FERITLogo.png"/>
                    <TextBlock Text="EAF CONTROL" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Margin="20,0">
                        <Ellipse x:Name="LedPlc" Width="14" Height="14" Fill="#F44336"/>
                        <TextBlock Text="PLC" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="20,0">
                        <Ellipse Width="14" Height="14" Fill="#4CAF50"/>
                        <TextBlock Text="BACKEND" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="20,0">
                        <Ellipse Width="14" Height="14" Fill="#FF9800"/>
                        <TextBlock Text="DATABASE" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" Background="#222222" CornerRadius="6"
                        Padding="10" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock x:Name="PlcAddressText"
                                   Text="192.168.0.1 | Rack 0 | Slot 1"
                                   Foreground="#DDDDDD" FontSize="12"/>
                        <TextBlock Text="CPU: S7-1500" Foreground="#00BFFF"
                                   FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#151515" BorderBrush="#2E2E2E" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <Button x:Name="ProcessBtn"    Content="PROCESS VIEW" Click="ProcessBtn_Click"    Style="{StaticResource NavBtnActive}"/>
                    <Button x:Name="ConnectionBtn" Content="CONNECTION"   Click="ConnectionBtn_Click" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="HistoryBtn"    Content="HISTORY"      Click="HistoryBtn_Click"    Style="{StaticResource NavBtn}"/>
                    <Button x:Name="AlarmsBtn"     Content="ALARMS"       Click="AlarmsBtn_Click"     Style="{StaticResource NavBtn}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">

                <Grid x:Name="ProcessPage" Visibility="Visible" Background="#101010">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="4" Margin="12,10">
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="TILTING"     Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TiltingValue" Text="0.0" Foreground="#00E5A0" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="°"           Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="WEIGHT"      Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="WeightValue" Text="0.0" Foreground="#E88080" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="T"           Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="CURRENT"     Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CurrentValue" Text="0" Foreground="#AADD44" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="A"           Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="TEMPERATURE" Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TempValue" Text="0" Foreground="#FF6B35" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="°C"          Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- FURNACE CANVAS -->
                        <Border Grid.Row="1" Background="#111111" Margin="12,0,12,12" CornerRadius="6">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="560" Height="360">

                                    <!-- Electrode canvas — electrodes sit here, animated via code-behind -->
                                    <Canvas x:Name="FurnaceCanvas" Width="560" Height="360">

                                        <!-- Electrode 1 -->
                                        <Rectangle x:Name="Electrode1"
                                                   Canvas.Left="148" Canvas.Top="10"
                                                   Width="18" Height="100"
                                                   RadiusX="3" RadiusY="3" Fill="#666666"/>
                                        <!-- Tip triangle -->
                                        <Polygon x:Name="ElTip1"
                                                 Points="148,120 166,120 157,136"
                                                 Fill="#888888"/>

                                        <!-- Electrode 2 -->
                                        <Rectangle x:Name="Electrode2"
                                                   Canvas.Left="271" Canvas.Top="10"
                                                   Width="18" Height="97"
                                                   RadiusX="3" RadiusY="3" Fill="#666666"/>
                                        <Polygon x:Name="ElTip2"
                                                 Points="271,120 289,120 280,136"
                                                 Fill="#888888"/>

                                        <!-- Electrode 3 -->
                                        <Rectangle x:Name="Electrode3"
                                                   Canvas.Left="394" Canvas.Top="10"
                                                   Width="18" Height="100"
                                                   RadiusX="3" RadiusY="3" Fill="#666666"/>
                                        <Polygon x:Name="ElTip3"
                                             Points="394,120 412,120 403,136"
                                             Fill="#888888"/>

                                        <!-- Sparks at electrode tips -->
                                        <Ellipse x:Name="Spark1" Canvas.Left="152" Canvas.Top="137" Width="10" Height="10" Fill="#AADD44" Opacity="0"/>
                                        <Ellipse x:Name="Spark2" Canvas.Left="275" Canvas.Top="137" Width="10" Height="10" Fill="#AADD44" Opacity="0"/>
                                        <Ellipse x:Name="Spark3" Canvas.Left="398" Canvas.Top="137" Width="10" Height="10" Fill="#AADD44" Opacity="0"/>
                                    </Canvas>

                                    <!-- Furnace body — centered, rotates around bottom-center -->
                                    <Canvas x:Name="FurnaceBody"
                                            Width="420" Height="200"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,60,0,0">
                                        <Canvas.RenderTransformOrigin>0.5,1.0</Canvas.RenderTransformOrigin>
                                        <Canvas.RenderTransform>
                                            <RotateTransform x:Name="FurnaceTilt" Angle="0"/>
                                        </Canvas.RenderTransform>

                                        <!-- Shell outline — flat bottom -->

                                        <Path Fill="#2A2A2A" Stroke="#666666" StrokeThickness="2.5">
                                            <Path.Data>
                                                <PathGeometry>
                                                    <PathFigure StartPoint="20,22" IsClosed="True">
                                                        <!-- Top left arc start to top right arc end -->
                                                        <ArcSegment Point="400,22" Size="210,30" SweepDirection="Clockwise"/>
                                                        <!-- Right side — straight down -->
                                                        <LineSegment Point="400,195"/>
                                                        <!-- Flat bottom -->
                                                        <LineSegment Point="20,195"/>
                                                        <!-- Left side — straight up -->
                                                        <LineSegment Point="20,22"/>
                                                    </PathFigure>
                                                </PathGeometry>
                                            </Path.Data>
                                        </Path>

                                        <!-- Material fill — grows upward from flat bottom -->
                                        <Rectangle x:Name="MaterialFill"
                                                   Canvas.Left="23" Canvas.Top="194"
                                                   Width="375" Height="0"
                                                   Fill="#CC4400" Opacity="0.88"/>

                                        <!-- Weight text overlay -->
                                        <TextBlock x:Name="WeightOverlay"
                                                   Canvas.Left="155" Canvas.Top="158"
                                                   Text="0.0 T  |  0%"
                                                   Foreground="#FFB080" FontSize="14" FontWeight="SemiBold"/>

                                        <!-- Tap spout -->
                                        <Rectangle Canvas.Left="380" Canvas.Top="190"
                                                   Width="20" Height="40"
                                                   Fill="#444444" Stroke="#666666" StrokeThickness="1"
                                                   RadiusX="2" RadiusY="2"/>
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Border>

                    </Grid>

                    <Border Grid.Column="1" Background="#181818"
                            BorderBrush="#2E2E2E" BorderThickness="1,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="18,20">

                                <TextBlock Text="PROCESS CONTROL" Foreground="White"
                                           FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <Border x:Name="OverfillBanner" Visibility="Collapsed"
                                        Background="#2A0A0A" BorderBrush="#CC2222"
                                        BorderThickness="0,0,0,2" CornerRadius="4"
                                        Padding="12,8" Margin="0,0,0,8">
                                    <TextBlock Text="⚠  FURNACE OVERFILL — stop loading"
                                               Foreground="#FF6666" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="OvertempBanner" Visibility="Collapsed"
                                        Background="#2A0A0A" BorderBrush="#CC2222"
                                        BorderThickness="0,0,0,2" CornerRadius="4"
                                        Padding="12,8" Margin="0,0,0,8">
                                    <TextBlock Text="⚠  OVERTEMPERATURE — reduce current"
                                               Foreground="#FF6666" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border x:Name="TapErrorBanner" Visibility="Collapsed"
                                        Background="#2A0A0A" BorderBrush="#CC2222"
                                        BorderThickness="0,0,0,2" CornerRadius="4"
                                        Padding="12,8" Margin="0,0,0,14">
                                    <TextBlock Text="⚠  TAPPING ERROR — check procedure"
                                               Foreground="#FF6666" FontSize="12" FontWeight="SemiBold"/>
                                </Border>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="LedScrap" Width="11" Height="11"
                                                 Fill="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="SCRAP LOADING" Foreground="#AAA"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Ellipse x:Name="LedTapping" Width="11" Height="11"
                                                 Fill="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="TAPPING ACTIVE" Foreground="#AAA"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="CURRENT SETPOINT (A)" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CurrentSetpointInput" Text="0"
                                             Style="{StaticResource FieldInput}"
                                             Margin="0"/>
                                    <Button x:Name="SetCurrentBtn" Grid.Column="2"
                                            Content="SET"
                                            Height="38"
                                            Background="#00BFFF" Foreground="White"
                                            FontWeight="Bold" FontSize="12"
                                            BorderBrush="{x:Null}"
                                            Click="SetCurrentBtn_Click"/>
                                </Grid>

                                <TextBlock Text="TAP ANGLE  (0° – 15°)" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="46"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="TapSlider" Minimum="0" Maximum="15"
                                            Value="0" Foreground="#00E5A0"
                                            VerticalAlignment="Center"
                                            />
                                    <TextBlock x:Name="TapAngleLabel" Grid.Column="1"
                                               Text="0.0°" Foreground="#00E5A0"
                                               FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <TextBlock Text="ENERGY CONSUMED" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,4">
                                    <ProgressBar x:Name="EnergyBar" Height="22"
                                                 Maximum="100" Value="0"
                                                 Background="#2A2A2A" Foreground="#00E5A0"
                                                 BorderBrush="{x:Null}"/>
                                    <TextBlock x:Name="EnergyLabel" Text="0 kWh"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" FontSize="11"/>
                                </Grid>
                                <TextBlock x:Name="EnergyPctLabel" Text="0%"
                                           Foreground="#666" FontSize="10"
                                           HorizontalAlignment="Right" Margin="0,2,0,18"/>

                                <Separator Background="#2E2E2E" Margin="0,0,0,16"/>

                                <Border x:Name="EmptyBanner" Visibility="Collapsed"
                                        Background="#1A2A1A" CornerRadius="4"
                                        Padding="10,6" Margin="0,0,0,12">
                                    <TextBlock Text="FURNACE EMPTY — ready for charging"
                                               Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold"/>
                                </Border>

                                <Button x:Name="LoadScrapBtn"
                                        Content="LOAD SCRAP  (+1 TON)"
                                        Style="{StaticResource ActionBtn}"
                                        Background="#1F5F2C"
                                        />

                                <Button x:Name="TapBtn"
                                        Content="TAP"
                                        Style="{StaticResource ActionBtn}"
                                        Background="#CC5500"
                                       />

                                <Button Content="RESET" Click="ResetBtn_Click"                                       
                                        Style="{StaticResource ActionBtn}"
                                        Background="#7A1A1A"
                                        Margin="0"
                                        />

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid x:Name="ConnectionPage" Visibility="Collapsed" Background="#101010">
                    <ScrollViewer>
                        <StackPanel Margin="25">
                            <TextBlock Text="PLC CONNECTION" Foreground="White"
                                       FontSize="24" FontWeight="Bold" Margin="0,0,0,25"/>
                            <Border Background="#1E1E1E" CornerRadius="8" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="IP ADDRESS" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="IpInput" Text="{Binding plcConnectionTab.Ip, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,16"/>

                                    <TextBlock Text="RACK" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="RackInput"  Text="{Binding plcConnectionTab.Rack, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,16"/>

                                    <TextBlock Text="SLOT" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SlotInput"  Text="{Binding plcConnectionTab.Slot, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,24"/>

                                    <TextBlock Text="CPU TYPE" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CpuTypeInput"
                                              Background="#2A2A2A" Foreground="Black"
                                              BorderBrush="#333" Padding="10,8"
                                              FontSize="14" Margin="0,0,0,24"
                                              SelectedIndex="{Binding plcConnectionTab.Cpu, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBoxItem Content="S7-1500"/>
                                        <ComboBoxItem Content="S7-1200"/>
                                        <ComboBoxItem Content="S7-400"/>
                                        <ComboBoxItem Content="S7-300"/>
                                    </ComboBox>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="CONNECT" 
                                                Command="{Binding plcConnectionTab.connectCommand}"
                                                Height="44"
                                                Background="#1F5F2C" Foreground="White"
                                                FontWeight="Bold" BorderBrush="{x:Null}"
                                                />
                                        <Button Grid.Column="2" Content="DISCONNECT" Height="44"
                                                Background="#7A1A1A" Foreground="White"
                                                FontWeight="Bold" BorderBrush="{x:Null}"
                                                />
                                    </Grid>

                                    <Border Margin="0,20,0,0" Background="#111111"
                                            CornerRadius="4" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="ConnStatusLed" Width="12" Height="12"
                                                     Fill="#F44336" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="ConnStatusText" Text="Not connected"
                                                       Foreground="#CCC" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>


                <Grid x:Name="HistoryPage" Visibility="Collapsed" Background="#101010">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EVENT HISTORY" Foreground="White"
                                        FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button x:Name="ClearHistoryBtn" Grid.Column="1"
                                    Content="CLEAR LOG" Height="34" Padding="16,0"
                                    Background="#333333" Foreground="#AAAAAA"
                                    FontWeight="Bold" FontSize="11" BorderBrush="{x:Null}"
                                    Click="ClearHistoryBtn_Click"/>
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                            <Border Margin="0,0,8,0" Background="#1E1E1E" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="TOTAL EVENTS" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="HistTotalEvents" Text="0" Foreground="#00BFFF"
                                                FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4,0" Background="#1E1E1E" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="ALARMS" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="HistAlarmCount" Text="0" Foreground="#FF4444"
                               FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,0" Background="#1E1E1E" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="LAST EVENT" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="HistLastTime" Text="—" Foreground="#AAAAAA"
                                                FontSize="13" FontWeight="Bold" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <DataGrid x:Name="HistoryGrid" Grid.Row="2"
                                  Background="#1E1E1E" Foreground="White"
                                  BorderBrush="#333" RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#242424"
                                  HeadersVisibility="Column" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2E2E2E"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                            <Setter Property="Foreground" Value="#FF8888"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME" Width="170"
                                    Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"/>
                                <DataGridTextColumn Header="TYPE" Width="100"
                                    Binding="{Binding EventType}"/>
                                <DataGridTextColumn Header="EVENT" Width="*"
                                    Binding="{Binding EventDescription}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>

                <Grid x:Name="AlarmsPage" Visibility="Collapsed" Background="#101010">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ACTIVE ALARMS" Foreground="White"
                                            FontSize="24" FontWeight="Bold"/>
                                <Border x:Name="AlarmCountBadge"
                                        Background="#CC2222" CornerRadius="10"
                                        Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="AlarmCountText" Text="0"
                                                Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button x:Name="AckAllBtn" Grid.Column="1"
                                    Content="ACK ALL" Height="34" Padding="16,0"
                                    Background="#7A1A1A" Foreground="White"
                                    FontWeight="Bold" FontSize="11" BorderBrush="{x:Null}"
                                    Click="AckAllBtn_Click"/>
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                            <Border Margin="0,0,8,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                    BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="OVERFILL" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedOverfill" Width="14" Height="14"
                                            Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                        BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="OVERTEMPERATURE" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedOvertemp" Width="14" Height="14"
                                             Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                    BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="TAPPING ERROR" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedTapError" Width="14" Height="14"
                                                Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <DataGrid x:Name="AlarmGrid" Grid.Row="2"
                                  Background="#1E1E1E" Foreground="White"
                                  BorderBrush="#333" RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#2A0A0A"
                                  HeadersVisibility="Column" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2E2E2E"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME" Width="170"
                                    Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"/>
                                <DataGridTextColumn Header="ALARM" Width="200"
                                    Binding="{Binding AlarmName}"/>
                                <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                    Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="STATUS" Width="110"
                                    Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>


            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                BorderBrush="#2E2E2E"
                BorderThickness="0,1,0,0">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="[14:21:55] Overtemperature cleared"
                               Foreground="#FF9800"
                               FontSize="12"/>

                    <TextBlock Text="[14:20:13] Shear cycle started"
                               Foreground="#00BFFF"
                               FontSize="12"/>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="EVENT: Process running normally"
                           Foreground="#DDDDDD"
                           FontSize="15"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <ToggleButton Content="AUTO"
                                  Width="90"
                                  Height="36"
                                  Margin="0,0,20,0"
                                  Background="#00BFFF"
                                  Foreground="White"
                                  FontWeight="Bold"/>

                    <TextBlock Text="18.05.2026 14:22:05"
                               Foreground="#DDDDDD"
                               VerticalAlignment="Center"
                               FontSize="14"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</UserControl>